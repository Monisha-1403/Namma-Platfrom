        <activity
            android:name=".ui.activities.FacilitiesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.EmergencyHelpActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.FeedbackActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.HappyJourneyActivity"
            android:exported="false" />

        <activity
