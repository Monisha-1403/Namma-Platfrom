<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NammaPlatform" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#071A52</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#FFD700</item>
        <item name="colorOnSecondary">#071A52</item>
        <item name="android:statusBarColor">#071A52</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:textColorPrimary">#071A52</item>
    </style>

    <style name="Theme.NammaPlatform.Splash" parent="Theme.NammaPlatform">
        <item name="android:windowBackground">@color/app_bg</item>
    </style>

    <style name="ButtonStyle" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearance">@style/RoundedShape</item>
        <item name="android:backgroundTint">#FFD700</item>
        <item name="android:textColor">#071A52</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RoundedShape">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
