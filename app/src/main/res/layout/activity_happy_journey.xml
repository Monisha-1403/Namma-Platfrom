<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_blue"
    android:padding="24dp">

    <ImageView
        android:id="@+id/iv_train_moving"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/ic_train_modern"
        android:contentDescription="@string/happy_journey"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/railway_yellow" />

    <TextView
        android:id="@+id/tv_shubha_prayana"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/shubha_prayana"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_train_moving" />

    <TextView
        android:id="@+id/tv_safe_journey"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/safe_journey"
        android:textColor="@color/railway_yellow"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_shubha_prayana" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_finish"
        style="@style/ButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="48dp"
        android:text="@string/finish"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
