<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_select_lang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:text="Select Language\nಭಾಷೆಯನ್ನು ಆಯ್ಕೆ ಮಾಡಿ"
        android:textColor="@color/app_text"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_kannada"
        style="@style/ButtonStyle"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="64dp"
        android:text="ಕನ್ನಡ"
        android:textSize="48sp"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_select_lang" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_english"
        style="@style/ButtonStyle"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="24dp"
        android:text="English"
        android:textSize="48sp"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_kannada" />

</androidx.constraintlayout.widget.ConstraintLayout>
